    return _resolve_value(
        config,
        project=project_id,
        comparative_analysis=comparative_analysis,
        allow_sample_overrides=False,
        path=["tarean_params", key],
    )


def stable_rserv_port(port_base: int, key: str, mod: int = 1000) -> int:
    """
    Deterministic Rserve port mapping that does NOT depend on Python's hash().
    This avoids interpreter-to-interpreter variability in Snakemake rule evaluation.
    """
    h = hashlib.md5(str(key).encode("utf-8")).hexdigest()
    return int(h, 16) % mod + int(port_base)


