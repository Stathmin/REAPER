def get_param(
    project_id,
    *keys,
    sample_id=None,
    comparative_analysis=None,
    comparative_context: bool = False,
):
    """Lookup config value with layered deep-merge semantics.

    Solo context: global → project → sample (when caller uses helpers that pass sample).
    Comparative context: sample overrides are disallowed; use analysis-level layer.
    """
    allow_sample = not bool(comparative_context)
    return _resolve_value(
        config,
        project=project_id,
        sample=sample_id,
        comparative_analysis=comparative_analysis,
        allow_sample_overrides=allow_sample,
        path=list(keys),
    )


def get_sample_prefix(project_id: str, sample_id: str) -> str:
    """Metadata-only sample prefix with strict fallback (no slicing magic)."""
    sm = get_sample_metadata(project_id, sample_id)
    raw = sm.get("prefix")
    if raw is None or str(raw).strip() == "":
        return str(sample_id).upper()
    return str(raw)


def comparative_prefix_map(project_id: str, comparative_analysis: str) -> dict[str, str]:
    """Return sample_id -> padded prefix (strict comparative metadata)."""
    samples = config["projects"][project_id]["comparative_analyses"][comparative_analysis]["samples"]
    base = {s: get_sample_prefix(project_id, s) for s in samples}
    maxlen = max(len(p) for p in base.values()) if base else 0
    floor = int(get_tarean_param(project_id, "prefix_length"))
    floor = max(floor, int(get_tarean_param_for_comparative(project_id, comparative_analysis, "prefix_length")))
    padlen = max(maxlen, floor)
    return {s: (p.ljust(padlen, "_")) for s, p in base.items()}


def comparative_prefix_length(project_id: str, comparative_analysis: str) -> int:
    m = comparative_prefix_map(project_id, comparative_analysis)
    return max((len(p) for p in m.values()), default=0)


def get_node_resources(project_id=None):
    """Return (cpu_count, mem_total_kb) using runtime detection where possible."""
    cpu = os.cpu_count() or 1
    mem_kb = None
    try:
        with open("/proc/meminfo", "r") as f:
            for line in f:
                if line.startswith("MemTotal:"):
                    # e.g. "MemTotal:       263838416 kB"
                    parts = line.split()
                    if len(parts) >= 2:
                        mem_kb = int(parts[1])
                    break
    except FileNotFoundError:
        mem_kb = None

    if mem_kb is None:
        # Fallback: derive from configured default_memory (e.g. "180G").
        default_mem = (
            str(get_param(project_id, "default_memory")) if project_id is not None else str(config["global"]["default_memory"])
        )
        if not default_mem.upper().endswith("G"):
            raise ValueError(f"default_memory must be a '<GiB>G' string, got: {default_mem!r}")
        gb_value = float(default_mem.upper().replace("G", ""))
        mem_kb = int(gb_value * 1024 * 1024)

    return cpu, mem_kb


def get_seqclust_threads(project_id, requested_threads):
    """Compute 80% CPU threads, capped by requested_threads."""
    cpu, _ = get_node_resources(project_id)
    cap = max(1, int(math.floor(cpu * 0.8)))
    req = int(requested_threads)
    return max(1, min(req, cap))


def _parse_percent_or_float(value) -> float:
    """
    Parse either:
      - "80%" -> 0.80
      - 0.80   -> 0.80
      - "0.8"  -> 0.8
      - 80     -> 0.80  (best-effort)
    """
    if value is None:
        raise ValueError("value is None")
    if isinstance(value, str):
        v = value.strip()
        if v.endswith("%"):
            return float(v[:-1]) / 100.0
        fv = float(v)
        return fv / 100.0 if fv > 1.0 else fv
    if isinstance(value, (int, float)):
        # If user passed 80 instead of 0.8, normalize best-effort.
        return float(value) / 100.0 if float(value) > 1.0 else float(value)
    return float(value)


def get_seqclust_memory_kb(project_id):
    """
    Compute seqclust RAM cap (and default -r value) in kB.

    The effective cap comes from `projects.<project>.tarean_params.memory_limit`
    (e.g. "80%"). `tarean_params.r_value` (if set) can further clamp the value.
    """
    _, mem_kb = get_node_resources(project_id)

    memory_limit_raw = get_tarean_param(project_id, "memory_limit")
    memory_limit_frac = _parse_percent_or_float(memory_limit_raw)

    cap = int(math.floor(mem_kb * memory_limit_frac))
    cap = max(1, cap)

    r_value_raw = get_tarean_param(project_id, "r_value")
    if r_value_raw is None:
        return cap

    # r_value can be a raw KB integer or a percent string (best-effort).
    if isinstance(r_value_raw, str) and r_value_raw.strip().endswith("%"):
        r_value_frac = _parse_percent_or_float(r_value_raw)
        r_value_kb = int(math.floor(mem_kb * r_value_frac))
    else:
        r_value_kb = int(r_value_raw)
    return max(1, min(r_value_kb, cap))


def get_tarean_param(project_id, key):
    """Project override -> global.tarean_params -> default.

    NOTE: sample-aware resolution is done via get_tarean_param_for_sample().
    """
    return _resolve_value(config, project=project_id, path=["tarean_params", key])


def get_tarean_param_for_sample(project_id, sample_id, key):
