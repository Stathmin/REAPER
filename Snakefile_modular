def get_sample_reads(project_id, sample_id):
    """Get read file paths for a sample"""
    # Use raw_reads directory with symbolic links.
    # Prefer gzipped links when present so tools auto-detect compression.
    raw_dir = Path(f"projects/{project_id}/samples/{sample_id}/raw_reads")
    candidates = [
        ("R1.fq.gz", "R2.fq.gz"),
        ("R1.fastq.gz", "R2.fastq.gz"),
        ("R1.fq", "R2.fq"),
        ("R1.fastq", "R2.fastq"),
    ]
    for r1_name, r2_name in candidates:
        r1 = raw_dir / r1_name
        r2 = raw_dir / r2_name
        if (r1.exists() and r2.exists()) or (r1.is_symlink() and r2.is_symlink()):
            return str(r1), str(r2)

    # Fallback: use configured absolute paths (allows running even if raw_reads was cleaned up).
    sample_cfg = config["projects"][project_id]["samples"][sample_id]
    r1_path = sample_cfg.get("r1_path")
    r2_path = sample_cfg.get("r2_path")
    if not (r1_path and r2_path):
        raise ValueError(
            f"Sample {project_id}/{sample_id} has no raw_reads symlinks and no r1_path/r2_path in config."
        )
    return str(r1_path), str(r2_path)

