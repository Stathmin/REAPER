# RepOrtR .gitignore
# This file separates installation artifacts from runtime files for easier management

# ===========================================
# INSTALLATION ARTIFACTS (External downloads)
# ===========================================
# repex_tarean is downloaded during installation
repex_tarean/

# Installation scripts and artifacts
activate_reportr.sh
install_artifacts/

# Legacy generated conda env files (no longer used)
environment_repeatexplorer.yml
environment_reportr.yml

# ===========================================
# RUNTIME FILES (Created during usage)
# ===========================================
# Output directories from Snakemake workflow
cleaned_reads/
fastqc_cleaned_reads/
interlaced/
tmp/

# Temporary and cache files
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
bin/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# Python virtual environments
venv/
env/
ENV/
.venv/
.env/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.node_modules/
node_modules/
.DS_Store
Thumbs.db

# Log files
*.log
logs/

# Benchmarks (Snakemake runtime artifacts)
benchmarks/

# Reports generated by pipeline runs (never commit)
*.xlsx
*.docx
*.done

# Data files (user-specific)
data/reads/*.fastq
data/reads/*.fq
data/reads/*.fq.gz
data/reads/*.fastq.gz

# Test outputs
tests/cleaned_reads/
tests/interlaced/
tests/tmp/

# ===========================================
# NEW TEST FILES AND TOY PROJECT
# ===========================================
# Test artifacts and outputs
tests/test_*.pyc
tests/__pycache__/
tests/.pytest_cache/
tests/.coverage
tests/htmlcov/
tests/.tox/
tests/.mypy_cache/

# Toy project outputs and temporary files
data/toy_project/output/
data/toy_project/tmp/
data/toy_project/*.log
data/toy_project/*.tmp
data/toy_project/*.temp
data/toy_project/__pycache__/
data/toy_project/*.pyc

# ===========================================
# SYSTEM FILES
# ===========================================
# Temporary files
*.tmp
*.temp
*.bak
*.backup

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ===========================================
# REPEX_TAREAN SPECIFIC (if kept in repo)
# ===========================================
# If repex_tarean is kept in the repo, ignore its runtime files
repex_tarean/tmp/
repex_tarean/*.log
repex_tarean/*.out
repex_tarean/*.err 
# Additional runtime files
.snakemake/
repeatexplorer_install.log

# ===========================================
# REFERENCES (Hidden from GitHub)
# ===========================================
# References folder contains research articles and should be hidden
/references/

# Other repo-local materials to keep untracked
/docs/
/apptainer/
/.dockerignore
/Dockerfile
/HOLY_WORKFLOW_PRINCIPLES.md

# ===========================================
# REFERENCES FOLDER (Now Included)
# ===========================================
# Include markdown files and .rdf files from references
# references/*.md
# references/*.rdf

# Exclude PDF files and their folders
references/repex/files/*/
references/**/*.pdf
references/**/*.PDF

# ===========================================
# CRITICAL RUNTIME DATA (MUST EXCLUDE)
# ===========================================
# Runtime projects policy: ignore almost everything under projects/, but Git must
# un-ignore parent directories for any tracked file (see gitignore(5) "re-include").
# Tracked templates only:
#   projects/global_config.yaml
#   projects/<project>/project_metadata.yaml
#   projects/<project>/samples/<sample>/metadata.yaml
#   projects/<project>/comparative/<analysis>/metadata.yaml
# Logs, benchmarks, root reports/, fastqc/, post_tarean/, tarean/, etc. stay untracked.

projects/*
!projects/global_config.yaml
!projects/*/
projects/*/*
!projects/*/project_metadata.yaml
!projects/*/samples/
projects/*/samples/*
!projects/*/samples/*/
projects/*/samples/*/*
!projects/*/samples/*/metadata.yaml
!projects/*/comparative/
projects/*/comparative/*
!projects/*/comparative/*/
projects/*/comparative/*/*
!projects/*/comparative/*/metadata.yaml

# Large test data files
data/probename_reads/*.fq
data/probename_reads/*.fastq

# Test outputs
test_outputs/

# Large log files
seqclust_test*.log

# Local backup snapshots (do not commit)
backups/

# Snakemake / shell nohup captures from interactive runs
nohup*.out
nohup.out

# Ad-hoc root outputs
docs/*.html

# Local validation marker (empty touch file from dry-runs)
workflow_validated.txt

# Temporary databases and cache
tmp/
.snakemake/

# ===========================================
# PRESERVED ESSENTIAL FILES (DO NOT IGNORE)
# ===========================================
# These files are essential and should be committed:
# - seqclust (wrapper script created by install_reportr.py)
# - projects/global_config.yaml (configuration template)
# - projects/*/project_metadata.yaml (project metadata templates)
# - projects/*/samples/*/metadata.yaml (sample metadata templates)

# ===========================================
# REPORTS (TRACKED)
# ===========================================
# User-requested: keep reports under version control.
!reports/
!reports/**
!projects/*/reports/
!projects/*/reports/**
